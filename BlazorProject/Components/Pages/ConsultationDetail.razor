        {
            return;
        }

        if (string.IsNullOrWhiteSpace(InviteEmail))
        {
            SetStatus("Introduza o email do utilizador a convidar.", true);
            return;
        }

        if (Consultation.Status == ConsultationData.ConsultationStatus.Encerrada)
        {
            SetStatus("Não é possível convidar utilizadores para uma consulta encerrada.", true);
            return;
        }

        if (TryGetDbConsultationId(out var idConsulta))
        {
            var loggedUser = LoggedInUserContext.CurrentUser;
            if (loggedUser is null)
            {
                SetStatus("Sessão inválida. Faça login novamente.", true);
                return;
            }

            var sendResult = await ConsultasService.SendInviteAsync(loggedUser.IdUtilizador, idConsulta, InviteEmail.Trim());
            if (!sendResult.Ok)
            {
                SetStatus(sendResult.Message, true);
                return;
            }

            InviteDialogOpen = false;
            InviteEmail = string.Empty;
            InviteAnnotation = string.Empty;
            await LoadConsultationFromRouteAsync();
            SetStatus(sendResult.Message);
            return;
        }

        var result = Store.SendInvite(Consultation.Id, InviteEmail, InviteAnnotation);
