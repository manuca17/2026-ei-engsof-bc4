    private void CloseEditDialog() => EditDialogOpen = false;

    private async Task SaveEdit()
    {
        if (Consultation is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(EditDescription))
        {
            SetStatus("A descrição é obrigatória.", true);
            return;
        }

        if (EditChargingType == "fixo" && (!EditFixedPrice.HasValue || EditFixedPrice <= 0))
        {
            SetStatus("Introduza um preço fixo válido.", true);
            return;
        }

        if (EditChargingType == "por_hora" && (!EditHourlyPrice.HasValue || EditHourlyPrice <= 0))
        {
            SetStatus("Introduza um preço por hora válido.", true);
            return;
        }

        var chargingType = EditChargingType == "por_hora"
            ? ConsultationData.ChargingType.PorHora
            : ConsultationData.ChargingType.Fixo;

        if (TryGetDbConsultationId(out var idConsulta))
        {
            var loggedUser = LoggedInUserContext.CurrentUser;
            if (loggedUser is null)
            {
                SetStatus("Sessão inválida. Faça login novamente.", true);
                return;
            }

            var dbChargingType = EditChargingType == "por_hora"
                ? ConsultasService.ChargingType.PorHora
                : ConsultasService.ChargingType.Fixo;

            var result = await ConsultasService.UpdateForDoctorAsync(
                loggedUser.IdUtilizador,
                idConsulta,
                new ConsultasService.UpdateConsultaRequest
                {
                    Description = EditDescription,
                    ChargingType = dbChargingType,
                    FixedPrice = dbChargingType == ConsultasService.ChargingType.Fixo ? EditFixedPrice : null,
                    HourlyPrice = dbChargingType == ConsultasService.ChargingType.PorHora ? EditHourlyPrice : null
                });

            if (!result.Ok)
            {
                SetStatus(result.ErrorMessage ?? "Não foi possível atualizar a consulta.", true);
                return;
            }

            EditDialogOpen = false;
            await LoadConsultationFromRouteAsync();
            SetStatus("Consulta atualizada com sucesso.");
            return;
        }

        if (!Store.UpdateConsultation(
                Consultation.Id,
                EditDescription,
                chargingType,
                chargingType == ConsultationData.ChargingType.Fixo ? EditFixedPrice : null,
                chargingType == ConsultationData.ChargingType.PorHora ? EditHourlyPrice : null))
        {
            SetStatus("Não foi possível atualizar a consulta.", true);
            return;
        }

        EditDialogOpen = false;
        LoadConsultation();
        SetStatus("Consulta atualizada com sucesso.");
    }

