    private async Task ConfirmRemoveExam()
    {
        Console.WriteLine("[DEBUG INTEL] ConfirmRemoveExam called with ExamToRemoveId: " + ExamToRemoveId + " and Consultation.Id: " + Consultation?.Id);
        if (Consultation is null || string.IsNullOrWhiteSpace(ExamToRemoveId))
        {
            return;
        }

        var loggedUser = LoggedInUserContext.CurrentUser;
        if (loggedUser is null)
        {
            SetStatus("Sessão inválida. Faça login novamente.", true);
            return;
        }

        if (TryGetDbConsultationId(out var idConsulta) && int.TryParse(ExamToRemoveId, out var idExameMedico))
        {
            var result = await ConsultasService.RemoveExamAsync(loggedUser.IdUtilizador, idConsulta, idExameMedico);
            if (!result.Ok)
            {
                SetStatus(result.Message, true);
                ExamToRemoveId = null;
                return;
            }

            ExamToRemoveId = null;
            await LoadConsultationFromRouteAsync();
            SetStatus(result.Message);
        }
        else
        {
            SetStatus("Não foi possível remover o exame.", true);
            ExamToRemoveId = null;
        }
    }

