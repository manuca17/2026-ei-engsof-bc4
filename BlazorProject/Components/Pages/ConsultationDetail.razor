    private async Task SaveExam()
    {
        if (Consultation is null)
        {
            return;
        }

        if (TryGetDbConsultationId(out var idConsulta))
        {
            var loggedUser = LoggedInUserContext.CurrentUser;
            if (loggedUser is null)
            {
                SetStatus("Sessão inválida. Faça login novamente.", true);
                return;
            }

            if (ExamMode == "new")
            {
                if (string.IsNullOrWhiteSpace(ExamName) || string.IsNullOrWhiteSpace(ExamType))
                {
                    SetStatus("Nome e tipo do exame são obrigatórios.", true);
                    return;
                }

                string? examFileName = null;
                string? examFilePath = null;
                if (ExamSelectedFile is not null)
                {
                    var upload = await SaveExamFileAsync(ExamSelectedFile);
                    if (upload is null)
                    {
                        SetStatus("Não foi possível carregar o ficheiro do exame.", true);
                        return;
                    }

                    var (originalFileName, relativePath) = upload.Value;
                    examFileName = originalFileName;
                    examFilePath = relativePath;
                }

                var addResult = await ConsultasService.AddNewExamAsync(
                    loggedUser.IdUtilizador,
                    idConsulta,
                    ExamDate.Date,
                    ExamType.Trim(),
                    string.IsNullOrWhiteSpace(ExamResults) ? null : ExamResults.Trim(),
                    examFileName,
                    examFilePath);

                if (!addResult.Ok)
                {
                    SetStatus(addResult.Message, true);
                    return;
                }

                CloseExamDialog();
                await LoadConsultationFromRouteAsync();
                SetStatus(addResult.Message);
                return;
            }

            if (string.IsNullOrWhiteSpace(SelectedExistingExamId) || !int.TryParse(SelectedExistingExamId, out var idExame))
            {
                SetStatus("Selecione um exame para associar.", true);
                return;
            }

            var associationResult = await ConsultasService.AssociateExamAsync(loggedUser.IdUtilizador, idConsulta, idExame);
            if (!associationResult.Ok)
            {
                SetStatus(associationResult.Message, true);
                return;
            }

            CloseExamDialog();
            await LoadConsultationFromRouteAsync();
            SetStatus(associationResult.Message);
            return;
        }

        if (ExamMode == "new")
        {
            if (string.IsNullOrWhiteSpace(ExamName) || string.IsNullOrWhiteSpace(ExamType))
            {
                SetStatus("Nome e tipo do exame são obrigatórios.", true);
                return;
            }

            var result = Store.CreateExam(Consultation.Id, ExamName, ExamType, ExamDate.Date, ExamDescription, ExamResults);
            if (!result.ok)
            {
                SetStatus(result.message, true);
                return;
            }

            CloseExamDialog();
            LoadConsultation();
            SetStatus(result.message);
            return;
        }

        if (string.IsNullOrWhiteSpace(SelectedExistingExamId))
        {
            SetStatus("Selecione um exame para associar.", true);
            return;
        }

        var association = Store.AssociateExistingExam(Consultation.Id, SelectedExistingExamId);
        if (!association.ok)
        {
            SetStatus(association.message, true);
            return;
        }

        CloseExamDialog();
        LoadConsultation();
        SetStatus(association.message);
    }

