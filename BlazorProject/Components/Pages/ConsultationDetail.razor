    private void RefreshAvailableExams()
    {
        if (Consultation is null)
        {
            AvailableExams = [];
            return;
        }

        AvailableExams = Store.GetExamsByPatient(Consultation.PatientId)
            .Where(exam => Consultation.Exams.All(existing => existing.Id != exam.Id))
            .OrderByDescending(exam => exam.Date)
            .ToList();
    }

    private async Task RefreshAvailableExamsAsync()
    {
        if (Consultation is null)
        {
            AvailableExams = [];
            return;
        }

        if (!TryGetDbConsultationId(out var idConsulta))
        {
            RefreshAvailableExams();
            return;
        }

        var loggedUser = LoggedInUserContext.CurrentUser;
        if (loggedUser is null)
        {
            AvailableExams = [];
            return;
        }

        var dbConsultation = await ConsultasService.GetDetailForDoctorAsync(loggedUser.IdUtilizador, idConsulta);
        if (dbConsultation is null)
        {
            AvailableExams = [];
            return;
        }

        AvailableExams = dbConsultation.AvailableExams
            .Select(exam => new ConsultationData.MedicalExamItem
            {
                Id = exam.Id.ToString(),
                PatientId = dbConsultation.PatientId?.ToString() ?? string.Empty,
                Name = exam.Name,
                Type = exam.Type,
                Date = exam.Date,
                Description = exam.Description,
                Results = exam.Results,
                CreatedAt = exam.Date
            })
            .OrderByDescending(exam => exam.Date)
            .ToList();
    }

