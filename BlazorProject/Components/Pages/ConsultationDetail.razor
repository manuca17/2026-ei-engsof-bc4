    private async Task<(string OriginalFileName, string RelativePath)?> SaveExamFileAsync(IBrowserFile file)
    {
        try
        {
            var uploadsFolder = Path.Combine(Environment.WebRootPath, "uploads", "exams");
            Directory.CreateDirectory(uploadsFolder);
            var extension = Path.GetExtension(file.Name);
            var generatedFileName = $"{Guid.NewGuid()}{extension}";
            var fullPath = Path.Combine(uploadsFolder, generatedFileName);

            await using var fileStream = File.Create(fullPath);
            await using var sourceStream = file.OpenReadStream(1024 * 1024 * 50);
            await sourceStream.CopyToAsync(fileStream);

            return (file.Name, $"/uploads/exams/{generatedFileName}");
        }
        catch
        {
            return null;
        }
    }

