@page "/dashboard"
@rendermode InteractiveServer
@using BlazorProject.Data.Services
@using BlazorProject.Services
@inject NavigationManager NavigationManager
@inject PacienteService PacienteService
@inject ConsultasService ConsultasService

<PageTitle>Dashboard</PageTitle>

<div class="dashboard">

    <!-- Header -->
    <div class="dash-header">
        <h1>Dashboard</h1>
        <p class="dash-subtitle">Bem-vindo de volta, @DoctorName</p>
    </div>

    <!-- Stat Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-top">
                <span class="stat-label">Total de Pacientes</span>
                <div class="stat-icon bg-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
            </div>
            <div class="stat-value">@(IsLoading ? "..." : TotalPatients.ToString())</div>
        </div>

        <div class="stat-card">
            <div class="stat-top">
                <span class="stat-label">Total de Consultas</span>
                <div class="stat-icon bg-green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
                        <line x1="16" x2="16" y1="2" y2="6"/>
                        <line x1="8" x2="8" y1="2" y2="6"/>
                        <line x1="3" x2="21" y1="10" y2="10"/>
                    </svg>
                </div>
            </div>
            <div class="stat-value">@(IsLoading ? "..." : TotalConsultations.ToString())</div>
        </div>

        <div class="stat-card">
            <div class="stat-top">
                <span class="stat-label">Consultas Pendentes</span>
                <div class="stat-icon bg-orange">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
            </div>
            <div class="stat-value">@(IsLoading ? "..." : PendingConsultations.ToString())</div>
        </div>

        <div class="stat-card">
            <div class="stat-top">
                <span class="stat-label">Receita Mensal</span>
                <div class="stat-icon bg-purple">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="#9333ea" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" x2="12" y1="2" y2="22"/>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                    </svg>
                </div>
            </div>
            <div class="stat-value">@(IsLoading ? "..." : $"€{MonthlyRevenue:N2}")</div>
        </div>
    </div>

    <!-- Bottom Cards -->
    <div class="bottom-grid">

        <!-- Ações Rápidas -->
        <div class="info-card">
            <div class="card-header">
                <h5>Ações Rápidas</h5>
            </div>
            <div class="card-body actions-list">
                <button class="action-btn" @onclick='() => NavigationManager.NavigateTo("/patients?newPatient=true")'>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    Registar Novo Paciente
                </button>
                <button class="action-btn" @onclick='() => NavigationManager.NavigateTo("/consultations")'>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
                        <line x1="16" x2="16" y1="2" y2="6"/>
                        <line x1="8" x2="8" y1="2" y2="6"/>
                        <line x1="3" x2="21" y1="10" y2="10"/>
                    </svg>
                    Agendar Consulta
                </button>
                <button class="action-btn" @onclick='() => NavigationManager.NavigateTo("/reports")'>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    Ver Relatórios
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string DoctorName { get; set; } = "Utilizador";
    private int TotalPatients { get; set; }
    private int TotalConsultations { get; set; }
    private int PendingConsultations { get; set; }
    private decimal MonthlyRevenue { get; set; }
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var loggedUser = LoggedInUserContext.CurrentUser;
        if (loggedUser is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        DoctorName = string.IsNullOrWhiteSpace(loggedUser.Nome) ? "Utilizador" : loggedUser.Nome;

        try
        {
            var patientsTask = PacienteService.GetByDoctorAsync(loggedUser.IdUtilizador);
            var statsTask = ConsultasService.GetDashboardStatsAsync(loggedUser.IdUtilizador);

            await Task.WhenAll(patientsTask, statsTask);

            TotalPatients = patientsTask.Result.Count;
            TotalConsultations = statsTask.Result.TotalConsultations;
            PendingConsultations = statsTask.Result.PendingConsultations;
            MonthlyRevenue = statsTask.Result.MonthlyRevenue;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
