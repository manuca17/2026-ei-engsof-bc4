@page "/"
@using BlazorProject.Data.Models
@using BlazorProject.Services
@layout LoginLayout
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject UtilizadorService UtilizadorService

<PageTitle>Login - Sistema de Gestão Médica</PageTitle>

<div class="login-bg">
    <div class="login-center">

        <!-- Header -->
        <div class="login-header">
            <div class="icon-circle">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                     fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/>
                    <path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"/>
                    <circle cx="20" cy="10" r="2"/>
                </svg>
            </div>
            <h1 class="login-title">Sistema de Gestão Médica</h1>
            <p class="login-subtitle">Gestão de consultas e pacientes</p>
        </div>

        <!-- Card com Tabs -->
        <div class="login-card">

            <!-- Tab Buttons -->
            <div class="tab-bar">
                <button class="tab-btn @(_tab == "login" ? "tab-active" : "")" @onclick='() => _tab = "login"'>
                    Login
                </button>
                <button class="tab-btn @(_tab == "register" ? "tab-active" : "")" @onclick='() => _tab = "register"'>
                    Registar
                </button>
            </div>

            <!-- Login Form -->
            @if (_tab == "login")
            {
                <div class="form-section">
                    <h5 class="form-title">Iniciar Sessão</h5>
                    <p class="form-desc">Aceda à sua conta para gerir consultas</p>

                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" class="form-control" @bind="_email" placeholder="joao@example.com" />
                    </div>
                    <div class="form-group">
                        <label>Senha</label>
                        <input type="password" class="form-control" @bind="_password" placeholder="••••••" />
                    </div>

                    <button class="btn-submit" @onclick="HandleLogin">
                        Entrar
                    </button>

                    @if (!string.IsNullOrEmpty(_erro))
                    {
                        <p style="color:red; margin-top:8px;">@_erro</p>
                    }

                    <div class="demo-accounts">
                        <p class="demo-title">Contas de demonstração:</p>
                        <p>Admin: admin@example.com / admin123</p>
                        <p>Médico: joao@example.com / 123456</p>
                    </div>
                </div>
            }

            <!-- Register Form -->
            @if (_tab == "register")
            {
                <div class="form-section">
                    <h5 class="form-title">Criar Conta</h5>
                    <p class="form-desc">Crie uma nova conta de utilizador</p>

                    <div class="form-group">
                        <label>Nome Completo</label>
                        <input type="text" class="form-control" placeholder="Dr. João Silva" />
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" class="form-control" placeholder="joao@example.com" />
                    </div>
                    <div class="form-group">
                        <label>Senha</label>
                        <input type="password" class="form-control" placeholder="••••••" />
                    </div>
                    <div class="form-group">
                        <label>Especialidade</label>
                        <input type="text" class="form-control" placeholder="Cardiologia" />
                    </div>
                    <div class="form-group">
                        <label>Telefone</label>
                        <input type="text" class="form-control" placeholder="+351 912 345 678" />
                    </div>

                    <button class="btn-submit" @onclick='() => NavigationManager.NavigateTo("/dashboard")'>
                        Criar Conta
                    </button>
                </div>
            }

        </div>
    </div>
    
</div>

@code {
    private string _tab = "login";
    private string _email = "";
    private string _password = "";
    private string _erro = "";

    private async Task HandleLogin()
    {
        try
        {
            Console.WriteLine($"[LOGIN] Tentativa de login com: {_email}");
            var utilizador = await UtilizadorService.LoginAsync(_email, _password);
            if (utilizador is not null)
            {
                LoggedInUserContext.SetCurrentUser(utilizador);
                Console.ForegroundColor = ConsoleColor.Green;
                Console.WriteLine($"[LOGIN] ✔ Login bem sucedido para: {_email}");
                Console.ResetColor();
                NavigationManager.NavigateTo("/dashboard");
            }
            else
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine($"[LOGIN] ✘ Login falhado para: {_email}");
                Console.ResetColor();
                _erro = "Email ou senha incorrectos.";
            }
        }
        catch (Exception ex)
        {
            Console.ForegroundColor = ConsoleColor.Red;
            Console.WriteLine($"[LOGIN] ✘ Excepção: {ex.Message}");
            Console.ResetColor();
            _erro = $"Erro interno: {ex.Message}";
        }
    }
    
    
}