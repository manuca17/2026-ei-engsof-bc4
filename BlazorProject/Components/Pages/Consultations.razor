@page "/consultations"
@using BlazorProject.Services
@using ConsultationData = BlazorProject.Services.ConsultasService
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ConsultasService ConsultasService

<PageTitle>Consultations</PageTitle>

<div class="consult-page">
    <div class="consult-header">
        <div>
            <h1>Gestao de Consultas</h1>
            <p>Total de @ConsultationItems.Count consulta@(ConsultationItems.Count == 1 ? "" : "s")</p>
        </div>
        <button class="btn-primary" @onclick="OpenDialog">
            <span>+</span>
            Nova Consulta
        </button>
    </div>

    <section class="panel">
        <div class="panel-title-row">
            <h3>Filtros</h3>
        </div>

        <div class="filter-grid">
            <div class="field">
                <label>Estado</label>
                <select @bind="FilterStatus">
                    <option value="all">Todos</option>
                    <option value="agendada">Agendada</option>
                    <option value="em_andamento">Em andamento</option>
                    <option value="encerrada">Encerrada</option>
                </select>
            </div>

            <div class="field">
                <label>Paciente</label>
                <select @bind="FilterPatient">
                    <option value="all">Todos</option>
                    @foreach (var patient in PatientOptions)
                    {
                        <option value="@patient.Id">@patient.Name</option>
                    }
                </select>
            </div>

            <div class="field">
                <label>Data inicio</label>
                <input type="date" @bind="DateFromInput" @bind:format="yyyy-MM-dd" />
            </div>

            <div class="field">
                <label>Data fim</label>
                <input type="date" @bind="DateToInput" @bind:format="yyyy-MM-dd" />
            </div>
        </div>

        <div class="filter-actions">
            <button class="btn-secondary" @onclick="ApplyDateFilter">Aplicar filtro de data</button>
            <button class="btn-outline" @onclick="ClearDateFilter">Limpar datas</button>
        </div>
    </section>

    @if (IsLoading)
    {
        <section class="panel empty">
            A carregar consultas...
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <section class="panel empty">
            @LoadError
        </section>
    }
    else if (FilteredConsultations.Count == 0)
    {
        <section class="panel empty">
            Nenhuma consulta encontrada
        </section>
    }
    else
    {
        <section class="cards-grid">
            @foreach (var consultation in FilteredConsultations)
            {
                <article class="consult-card" @onclick='() => NavigationManager.NavigateTo($"/consultations/{consultation.Id}")'>
                    <div class="card-top">
                        <h4>@consultation.PatientName</h4>
                        <span class="status @StatusClass(consultation.Status)">@StatusLabel(consultation.Status)</span>
                    </div>

                    <p class="desc">@consultation.Description</p>

                    @if (consultation.StartAt is not null)
                    {
                        <p class="meta">@consultation.StartAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                    }

                    <p class="meta"><strong>Cobranca:</strong> @ChargingText(consultation)</p>

                    <div class="details">
                        <div><span>Exames:</span><strong>@consultation.ExamsCount</strong></div>
                        <div><span>Anotacoes:</span><strong>@consultation.NotesCount</strong></div>
                        <div><span>Convites:</span><strong>@consultation.InvitesCount</strong></div>
                    </div>
                </article>
            }
        </section>
    }
</div>

@if (DialogOpen)
{
    <div class="modal-backdrop" @onclick="CloseDialog">
        <div class="dialog-panel" @onclick:stopPropagation="true">
            <div class="dialog-header">
                <h3>Criar Nova Consulta</h3>
                <p>Preencha os dados da consulta abaixo</p>
            </div>

            <div class="dialog-body">
                <div class="field">
                    <label>Paciente</label>
                    <select @bind="FormPatientId">
                        <option value="">Selecione um paciente</option>
                        @foreach (var patient in PatientOptions)
                        {
                            <option value="@patient.Id">@patient.Name</option>
                        }
                    </select>
                </div>

                <div class="field">
                    <label>Descricao</label>
                    <textarea rows="3" placeholder="Motivo da consulta..." @bind="FormDescription"></textarea>
                </div>

                <div class="field">
                    <label>Tipo de cobranca</label>
                    <select @bind="FormChargingType">
                        <option value="fixo">Preco fixo</option>
                        <option value="por_hora">Preco por hora</option>
                    </select>
                </div>

                @if (FormChargingType == "fixo")
                {
                    <div class="field">
                        <label>Preco fixo (EUR)</label>
                        <input type="number" step="0.01" placeholder="80.00" @bind="FormFixedPrice" />
                    </div>
                }
                else
                {
                    <div class="field">
                        <label>Preco por hora (EUR)</label>
                        <input type="number" step="0.01" placeholder="60.00" @bind="FormHourlyPrice" />
                    </div>
                }
            </div>

            <div class="dialog-actions">
                <button class="btn-primary" @onclick="CreateConsultationAsync" disabled="@IsCreating">
                    @(IsCreating ? "A criar..." : "Criar Consulta")
                </button>
                <button class="btn-outline" @onclick="CloseDialog">Cancelar</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "patient")]
    public string? PatientIdFromQuery { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "openForm")]
    public string? OpenFormFromQuery { get; set; }

    private bool DialogOpen;
    private bool IsLoading = true;
    private bool IsCreating;
    private string? LoadError;
    private int? LoggedDoctorId;

    private List<ConsultationData.ConsultationListItem> ConsultationItems { get; set; } = [];
    private List<ConsultationData.PatientOptionItem> PatientOptions { get; set; } = [];

    private string FilterStatus = "all";
    private string FilterPatient = "all";
    private DateTime? DateFromInput;
    private DateTime? DateToInput;
    private DateTime? DateFromApplied;
    private DateTime? DateToApplied;

    private string FormPatientId = string.Empty;
    private string FormDescription = string.Empty;
    private string FormChargingType = "fixo";
    private decimal? FormFixedPrice = 80m;
    private decimal? FormHourlyPrice = 60m;

    protected override async Task OnInitializedAsync()
    {
        var loggedUser = LoggedInUserContext.CurrentUser;
        if (loggedUser is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        LoggedDoctorId = loggedUser.IdUtilizador;

        if (!string.IsNullOrWhiteSpace(PatientIdFromQuery))
        {
            FilterPatient = PatientIdFromQuery;
        }

        if (OpenFormFromQuery == "true")
        {
            DialogOpen = true;
        }

        await LoadPageDataAsync();
    }

    private List<ConsultationData.ConsultationListItem> FilteredConsultations => ConsultationItems.Where(consultation =>
    {
        if (FilterStatus != "all" && StatusValue(consultation.Status) != FilterStatus)
        {
            return false;
        }

        if (FilterPatient != "all" && consultation.PatientId?.ToString() != FilterPatient)
        {
            return false;
        }

        if (DateFromApplied is not null)
        {
            if (consultation.StartAt is null || consultation.StartAt.Value.Date < DateFromApplied.Value.Date)
            {
                return false;
            }
        }

        if (DateToApplied is not null)
        {
            if (consultation.StartAt is null || consultation.StartAt.Value.Date > DateToApplied.Value.Date)
            {
                return false;
            }
        }

        return true;
    }).OrderByDescending(consultation => consultation.StartAt ?? DateTime.MinValue).ToList();

    private void OpenDialog() => DialogOpen = true;

    private void CloseDialog() => DialogOpen = false;

    private void ApplyDateFilter()
    {
        DateFromApplied = DateFromInput?.Date;
        DateToApplied = DateToInput?.Date;
    }

    private void ClearDateFilter()
    {
        DateFromInput = null;
        DateToInput = null;
        DateFromApplied = null;
        DateToApplied = null;
    }

    private async Task CreateConsultationAsync()
    {
        if (LoggedDoctorId is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        if (string.IsNullOrWhiteSpace(FormPatientId))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Selecione um paciente para criar a consulta.");
            return;
        }

        if (string.IsNullOrWhiteSpace(FormDescription))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Adicione uma descrição para a consulta.");
            return;
        }

        if (FormChargingType == "fixo" && (!FormFixedPrice.HasValue || FormFixedPrice <= 0))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Introduza um preço fixo válido.");
            return;
        }

        if (FormChargingType == "por_hora" && (!FormHourlyPrice.HasValue || FormHourlyPrice <= 0))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Introduza um preço por hora válido.");
            return;
        }

        if (!int.TryParse(FormPatientId, out var parsedPatientId))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Paciente inválido.");
            return;
        }

        var chargingType = FormChargingType == "por_hora" ? ConsultationData.ChargingType.PorHora : ConsultationData.ChargingType.Fixo;

        try
        {
            IsCreating = true;

            var result = await ConsultasService.CreateForDoctorAsync(new ConsultationData.CreateConsultaRequest
            {
                IdUtilizador = LoggedDoctorId.Value,
                IdPaciente = parsedPatientId,
                Description = FormDescription.Trim(),
                ChargingType = chargingType,
                FixedPrice = chargingType == ConsultationData.ChargingType.Fixo ? FormFixedPrice : null,
                HourlyPrice = chargingType == ConsultationData.ChargingType.PorHora ? FormHourlyPrice : null
            });

            if (!result.Ok)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Erro ao criar consulta: {result.ErrorMessage}");
                return;
            }

            FormPatientId = string.Empty;
            FormDescription = string.Empty;
            FormChargingType = "fixo";
            FormFixedPrice = 80m;
            FormHourlyPrice = 60m;
            DialogOpen = false;

            await LoadConsultationsAsync();
            await JSRuntime.InvokeVoidAsync("alert", "Consulta criada com sucesso!");
        }
        finally
        {
            IsCreating = false;
        }
    }

    private async Task LoadPageDataAsync()
    {
        try
        {
            IsLoading = true;
            LoadError = null;

            await LoadPatientsAsync();
            await LoadConsultationsAsync();
        }
        catch (Exception ex)
        {
            LoadError = $"Erro ao carregar consultas: {ex.Message}";
            ConsultationItems = [];
            PatientOptions = [];
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadPatientsAsync()
    {
        if (LoggedDoctorId is null)
        {
            PatientOptions = [];
            return;
        }

        PatientOptions = await ConsultasService.GetPatientsForDoctorAsync(LoggedDoctorId.Value);
    }

    private async Task LoadConsultationsAsync()
    {
        if (LoggedDoctorId is null)
        {
            ConsultationItems = [];
            return;
        }

        ConsultationItems = await ConsultasService.GetForDoctorAsync(LoggedDoctorId.Value);
    }

    private static string StatusClass(ConsultationData.ConsultationStatus status) => status switch
    {
        ConsultationData.ConsultationStatus.Agendada => "status-gray",
        ConsultationData.ConsultationStatus.EmAndamento => "status-blue",
        ConsultationData.ConsultationStatus.Encerrada => "status-green",
        _ => "status-gray"
    };

    private static string StatusLabel(ConsultationData.ConsultationStatus status) => status switch
    {
        ConsultationData.ConsultationStatus.Agendada => "Agendada",
        ConsultationData.ConsultationStatus.EmAndamento => "Em andamento",
        ConsultationData.ConsultationStatus.Encerrada => "Encerrada",
        _ => "Desconhecido"
    };

    private static string StatusValue(ConsultationData.ConsultationStatus status) => status switch
    {
        ConsultationData.ConsultationStatus.Agendada => "agendada",
        ConsultationData.ConsultationStatus.EmAndamento => "em_andamento",
        ConsultationData.ConsultationStatus.Encerrada => "encerrada",
        _ => "all"
    };

    private static string ChargingText(ConsultationData.ConsultationListItem consultation)
    {
        if (consultation.ChargingType == ConsultationData.ChargingType.Fixo)
        {
            var value = consultation.FixedPrice ?? 0m;
            return $"EUR {value:0.00} (fixo)";
        }

        var hourly = consultation.HourlyPrice ?? 0m;
        return $"EUR {hourly:0.00}/hora";
    }
}
