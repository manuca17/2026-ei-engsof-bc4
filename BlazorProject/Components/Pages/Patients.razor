@page "/patients"
@using BlazorProject.Data.Models
@using BlazorProject.Data.Services
@using BlazorProject.Services
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@inject PacienteService PatientService
@inject NavigationManager NavigationManager

<PageTitle>Pacientes</PageTitle>

<div class="patients-page p-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
        <div>
            <h1 class="h3 mb-1">Gestão de Pacientes</h1>
            <p class="text-muted mb-0">
                Total de @PatientList.Count paciente@(@PatientList.Count == 1 ? "" : "s")
            </p>
        </div>
        <button class="btn btn-primary" @onclick="() => DialogOpen = true">
            <span class="me-2">+</span>
            Novo Paciente
        </button>
    </div>

    <div class="mb-4">
        <input class="form-control"
               placeholder="Pesquisar pacientes por nome..."
               @bind="SearchTerm"
               @bind:event="oninput" />
    </div>

    @if (FilteredPatients.Count == 0)
    {
        <div class="card">
            <div class="card-body text-center text-muted py-5">
                @(string.IsNullOrWhiteSpace(SearchTerm) ? "Nenhum paciente registado ainda" : "Nenhum paciente encontrado")
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var patient in FilteredPatients)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title d-flex align-items-center">
                                <span class="badge bg-primary me-2">👤</span>
                                @patient.Nome
                            </h5>

                            <div class="text-muted small mb-2">
                                @CalculateAge(patient.DtNasc) anos (@(patient.DtNasc?.ToString("dd/MM/yyyy") ?? "N/A"))
                            </div>

                            <div class="mb-2">
                                <div class="small text-muted">Telefone</div>
                                <div>@(patient.Telefone ?? "---")</div>
                            </div>

                            <button class="btn btn-outline-primary w-100 mt-auto" @onclick="() => NavigateToPatientConsultations(patient.IdPaciente)">
                                Ver Consultas
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (DialogOpen)
{
    <div class="modal show d-block" style="background-color: rgba(0, 0, 0, 0.5);" @onclick="CloseDialog">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Registar Novo Paciente</h5>
                    <button type="button" class="btn-close" @onclick="CloseDialog"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nome Completo *</label>
                        <input class="form-control" @bind="NewPatient.Nome" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Data de Nascimento *</label>
                        @* Bind to the Helper because standard HTML date inputs prefer DateTime *@
                        <input type="date" class="form-control" @bind="BirthDateHelper" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Telefone *</label>
                        <input type="tel" class="form-control" @bind="NewPatient.Telefone" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" @bind="NewPatient.Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Rua / Porta</label>
                        <input class="form-control" @bind="NewPatient.Rua" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseDialog">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="SavePatient">Registar Paciente</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool DialogOpen;
    private string SearchTerm { get; set; } = string.Empty;
    private List<Paciente> PatientList { get; set; } = new();
    private Paciente NewPatient { get; set; } = new();
    
    // Bridge between UI (DateTime) and Database (DateOnly)
    private DateTime? BirthDateHelper { get; set; }

    private IReadOnlyList<Paciente> FilteredPatients => PatientList
        .Where(p => string.IsNullOrWhiteSpace(SearchTerm) || 
                    p.Nome.Contains(SearchTerm, StringComparison.InvariantCultureIgnoreCase))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadPatients();
        
        var uri = new Uri(NavigationManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        if (query["newPatient"] == "true")
        {
            DialogOpen = true;
            NavigationManager.NavigateTo("/patients", replace: true);
        }
    }

    private async Task LoadPatients()
    {
        int doctorId = LoggedInUserContext.CurrentUser?.IdUtilizador ?? 0;
        PatientList = await PatientService.GetByDoctorAsync(doctorId);
    }

    private void NavigateToPatientConsultations(int patientId)
    {
        NavigationManager.NavigateTo($"/consultations?patient={patientId}");
    }

    private int CalculateAge(DateOnly? birthDate)
    {
        if (!birthDate.HasValue) return 0;
        var today = DateOnly.FromDateTime(DateTime.Today);
        var age = today.Year - birthDate.Value.Year;
        if (birthDate.Value > today.AddYears(-age)) age--;
        return age;
    }

    private async Task SavePatient()
    {
        int doctorId = LoggedInUserContext.CurrentUser?.IdUtilizador ?? 0;

        // Validation
        if (doctorId <= 0)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Sessão inválida. Inicie sessão novamente.");
            return;
        }

        if (string.IsNullOrWhiteSpace(NewPatient.Nome) ||
            string.IsNullOrWhiteSpace(NewPatient.Telefone) ||
            !BirthDateHelper.HasValue)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Por favor, preencha o Nome, Data de Nascimento e Telefone.");
            return;
        }

        if (!Regex.IsValidPhoneNumber(NewPatient.Telefone))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Número de telefone inválido.");
            return;
        }

        if (!string.IsNullOrWhiteSpace(NewPatient.Email) && !Regex.IsValidEmail(NewPatient.Email))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Email inválido.");
            return;
        }

        try 
        {
            // Transfer helper date to model
            NewPatient.DtNasc = DateOnly.FromDateTime(BirthDateHelper.Value);

            await PatientService.SavePacienteAsync(NewPatient, doctorId);
            
            await LoadPatients(); 
            CloseDialog();
            await JSRuntime.InvokeVoidAsync("alert", "Paciente registado com sucesso!");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Erro ao guardar: " + ex.Message);
        }
    }

    private void CloseDialog()
    {
        DialogOpen = false;
        NewPatient = new Paciente();
        BirthDateHelper = null;
    }
}