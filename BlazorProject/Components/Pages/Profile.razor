@page "/profile"
@using BlazorProject.Data.Models
@using BlazorProject.Services
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject UtilizadorService UtilizadorService
@inject ConsultasService ConsultasService

<PageTitle>Perfil</PageTitle>

@if (IsLoading)
{
    <div class="text-center py-5">Carregando...</div>
}
else if (CurrentUser is null)
{
    <div class="text-center py-5 text-muted">Redirecionando...</div>
}
else
{
    <div class="max-w-2xl mx-auto space-y-6">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h1 class="h3 mb-2">Meu Perfil</h1>
                <p class="text-muted mb-0">Gerir as suas informações pessoais</p>
            </div>
            @if (!IsEditing)
            {
                <button class="btn btn-primary" @onclick="() => IsEditing = true">
                    <span class="me-2">✎</span>
                    Editar
                </button>
            }
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Informações Pessoais</h5>
            </div>
            <div class="card-body">
                @if (!IsEditing)
                {
                    <div class="space-y-4">
                        <div class="d-flex align-items-center gap-3 p-3 bg-light rounded">
                            <span class="fs-5 text-secondary">👤</span>
                            <div class="flex-grow-1">
                                <p class="text-muted small mb-0">Nome</p>
                                <p class="fw-semibold mb-0">@CurrentUser.Nome</p>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3 p-3 bg-light rounded">
                            <span class="fs-5 text-secondary">✉️</span>
                            <div class="flex-grow-1">
                                <p class="text-muted small mb-0">Email</p>
                                <p class="fw-semibold mb-0">@CurrentUser.Email</p>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3 p-3 bg-light rounded">
                            <span class="fs-5 text-secondary">💼</span>
                            <div class="flex-grow-1">
                                <p class="text-muted small mb-0">Especialidade</p>
                                <p class="fw-semibold mb-0">@(!string.IsNullOrWhiteSpace(CurrentUser.Especialidade) ? CurrentUser.Especialidade : "Não definida")</p>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3 p-3 bg-light rounded">
                            <span class="fs-5 text-secondary">📞</span>
                            <div class="flex-grow-1">
                                <p class="text-muted small mb-0">Telefone</p>
                                <p class="fw-semibold mb-0">@(!string.IsNullOrWhiteSpace(CurrentUser.Telefone) ? CurrentUser.Telefone : "Não definido")</p>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <form onsubmit="return false;">
                        <div class="mb-3">
                            <label class="form-label" for="nome">Nome Completo *</label>
                            <input id="nome" class="form-control" @bind="FormData.Nome" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="email">Email *</label>
                            <input id="email" type="email" class="form-control" @bind="FormData.Email" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="especialidade">Especialidade</label>
                            <input id="especialidade" class="form-control" placeholder="Ex: Cardiologia" @bind="FormData.Especialidade" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="telefone">Telefone</label>
                            <input id="telefone" class="form-control" placeholder="+351 912 345 678" @bind="FormData.Telefone" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="senha">Nova Senha (deixe em branco para não alterar)</label>
                            <input id="senha" type="password" class="form-control" placeholder="••••••" @bind="FormData.Senha" />
                        </div>

                        <div class="d-flex gap-3 pt-2">
                            <button class="btn btn-primary flex-grow-1" type="button" @onclick="SaveProfileAsync">Salvar Alterações</button>
                            <button class="btn btn-outline-secondary flex-grow-1" type="button" @onclick="CancelEdit">Cancelar</button>
                        </div>
                    </form>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Estatísticas da Conta</h5>
            </div>
            <div class="card-body">
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded">
                        <span class="text-muted">Membro desde</span>
                        <span class="fw-semibold">fix</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded">
                        <span class="text-muted">ID do Utilizador</span>
                        <span class="fw-monospace text-truncate" style="max-width: 240px;">@CurrentUser.IdUtilizador</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Convites para Consultas</h5>
                <span class="badge bg-primary">@PendingInvites.Count</span>
            </div>
            <div class="card-body">
                @if (PendingInvites.Count == 0)
                {
                    <div class="text-muted text-center py-3">Sem convites pendentes.</div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var invite in PendingInvites)
                        {
                            <div class="p-3 border rounded bg-light">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div>
                                        <div class="fw-semibold">@invite.PatientName</div>
                                        <div class="small text-muted">Convidado por: @invite.OwnerName</div>
                                        @if (invite.StartAt is not null)
                                        {
                                            <div class="small text-muted">Início: @invite.StartAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                        }
                                    </div>
                                    <span class="badge bg-warning text-dark">Pendente</span>
                                </div>
                                <div class="d-flex gap-2 mt-3">
                                    <button class="btn btn-sm btn-success" @onclick="() => AcceptInviteAsync(invite.IdConsulta)">Aceitar</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeclineInviteAsync(invite.IdConsulta)">Recusar</button>
                                    <button class="btn btn-sm btn-outline-primary" @onclick='() => NavigationManager.NavigateTo($"/consultations/{invite.IdConsulta}")'>Ver consulta</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool IsEditing;
    private bool IsLoading = true;

    private Utilizador? CurrentUser;
    private ProfileForm FormData { get; set; } = new();
    private List<ConsultasService.PendingInviteItem> PendingInvites { get; set; } = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadUserAsync();
    }

    private async Task LoadUserAsync()
    {
        CurrentUser = LoggedInUserContext.CurrentUser;

        if (CurrentUser is null)
        {
            IsLoading = false;
            NavigationManager.NavigateTo("/");
            return;
        }

        ResetForm();
        PendingInvites = await ConsultasService.GetPendingInvitesForDoctorAsync(CurrentUser.IdUtilizador);
        IsLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void ResetForm()
    {
        if (CurrentUser is null) return;

        FormData = new ProfileForm
        {
            Nome = CurrentUser.Nome,
            Email = CurrentUser.Email,
            Especialidade = CurrentUser.Especialidade ?? string.Empty,
            Telefone = CurrentUser.Telefone ?? string.Empty,
            Senha = string.Empty
        };
    }

    private async Task SaveProfileAsync()
    {
        if (CurrentUser is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        if (string.IsNullOrWhiteSpace(FormData.Nome) || string.IsNullOrWhiteSpace(FormData.Email))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Nome e email são obrigatórios.");
            return;
        }

        var updatedUser = new Utilizador(
            CurrentUser.IdUtilizador,
            CurrentUser.IsManager,
            CurrentUser.IsAdmin,
            FormData.Nome.Trim(),
            CurrentUser.Username,
            string.IsNullOrWhiteSpace(FormData.Senha) ? CurrentUser.Password : FormData.Senha,
            string.IsNullOrWhiteSpace(FormData.Telefone) ? null : FormData.Telefone.Trim(),
            FormData.Email.Trim(),
            CurrentUser.NumPorta,
            CurrentUser.Rua,
            CurrentUser.CodPostal,
            CurrentUser.NumCarteira,
            string.IsNullOrWhiteSpace(FormData.Especialidade) ? null : FormData.Especialidade.Trim(),
            CurrentUser.CodPostalNavigation);

        var savedUser = await UtilizadorService.UpdateAsync(updatedUser);
        CurrentUser = savedUser;
        LoggedInUserContext.SetCurrentUser(savedUser);

        IsEditing = false;
        ResetForm();
        await JSRuntime.InvokeVoidAsync("alert", "Perfil atualizado com sucesso.");
    }

    private async Task AcceptInviteAsync(int idConsulta)
    {
        if (CurrentUser is null)
        {
            return;
        }

        var result = await ConsultasService.AcceptInviteAsync(CurrentUser.IdUtilizador, idConsulta);
        if (!result.Ok)
        {
            await JSRuntime.InvokeVoidAsync("alert", result.Message);
            return;
        }

        PendingInvites = await ConsultasService.GetPendingInvitesForDoctorAsync(CurrentUser.IdUtilizador);
    }

    private async Task DeclineInviteAsync(int idConsulta)
    {
        if (CurrentUser is null)
        {
            return;
        }

        var result = await ConsultasService.DeclineInviteAsync(CurrentUser.IdUtilizador, idConsulta);
        if (!result.Ok)
        {
            await JSRuntime.InvokeVoidAsync("alert", result.Message);
            return;
        }

        PendingInvites = await ConsultasService.GetPendingInvitesForDoctorAsync(CurrentUser.IdUtilizador);
    }

    private void CancelEdit()
    {
        IsEditing = false;
        ResetForm();
    }

    private sealed class ProfileForm
    {
        public string Nome { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Especialidade { get; set; } = string.Empty;
        public string Telefone { get; set; } = string.Empty;
        public string Senha { get; set; } = string.Empty;
    }
}
