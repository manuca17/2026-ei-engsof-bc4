@page "/reports"
@page "/relatorios"
@using System.Text.Json.Serialization
@using BlazorProject.Services
@using ConsultationData = BlazorProject.Services.ConsultationStore
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@inject ConsultationStore Store

<PageTitle>Relatórios</PageTitle>

@if (IsLoading)
{
    <div class="reports-page">
        <section class="reports-card reports-empty">A carregar relatórios...</section>
    </div>
}
else
{
    <div class="reports-page">
        <div class="reports-header">
            <div>
                <h1>Relatórios</h1>
                <p>Consulte relatórios mensais detalhados</p>
            </div>
        </div>

        <section class="reports-card filters-card">
            <div class="section-heading">
                <h2>Período do Relatório</h2>
            </div>

            <div class="filters-grid">
                <div class="field">
                    <label>Mês</label>
                    <select @bind="SelectedMonth" @bind:after="OnPeriodChanged">
                        @foreach (var month in Months)
                        {
                            <option value="@month.Value">@month.Label</option>
                        }
                    </select>
                </div>

                <div class="field">
                    <label>Ano</label>
                    <select @bind="SelectedYear" @bind:after="OnPeriodChanged">
                        @foreach (var year in Years)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>
            </div>
        </section>

        <div class="reports-tabs">
            <button type="button"
                    class="@(ActiveTab == ReportsTab.User ? "tab-button active" : "tab-button")"
                    @onclick='() => ActiveTab = ReportsTab.User'>
                Meu Relatório
            </button>
            <button type="button"
                    class="@(ActiveTab == ReportsTab.Patient ? "tab-button active" : "tab-button")"
                    @onclick='() => ActiveTab = ReportsTab.Patient'>
                Relatório por Paciente
            </button>
        </div>

        @if (ActiveTab == ReportsTab.User)
        {
            <div class="reports-section">
                <div class="stats-grid">
                    <article class="stats-card stats-blue">
                        <div class="stats-label">Total de Horas</div>
                        <div class="stats-value">@UserReport.TotalHoras.ToString("F2")h</div>
                    </article>
                    <article class="stats-card stats-green">
                        <div class="stats-label">Receita Total</div>
                        <div class="stats-value">€@UserReport.TotalPreco.ToString("F2")</div>
                    </article>
                    <article class="stats-card stats-purple">
                        <div class="stats-label">Consultas Encerradas</div>
                        <div class="stats-value">@UserReport.TotalConsultas</div>
                    </article>
                </div>

                <section class="reports-card">
                    <div class="section-heading">
                        <h2>Detalhes por Dia</h2>
                    </div>

                    @if (UserReport.Dias.Count == 0)
                    {
                        <div class="reports-empty">Nenhuma consulta encerrada neste período.</div>
                    }
                    else
                    {
                        <div class="days-list">
                            @foreach (var day in UserReport.Dias)
                            {
                                <article class="day-card">
                                    <div class="day-header">
                                        <h3>Dia @day.Dia - @SelectedMonthLabel</h3>
                                        @if (day.Overtime)
                                        {
                                            <span class="status-pill status-danger">Overtime</span>
                                        }
                                    </div>

                                    <div class="table-wrap">
                                        <table class="reports-table">
                                            <thead>
                                                <tr>
                                                    <th>Paciente</th>
                                                    <th>Descrição</th>
                                                    <th class="text-right">Horas</th>
                                                    <th class="text-right">Preço</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var consultation in day.Consultas)
                                                {
                                                    <tr>
                                                        <td>@consultation.PacienteNome</td>
                                                        <td class="truncate-cell">@consultation.Descricao</td>
                                                        <td class="text-right">@consultation.Horas.ToString("F2")h</td>
                                                        <td class="text-right">€@consultation.Preco.ToString("F2")</td>
                                                    </tr>
                                                }
                                                <tr class="summary-row">
                                                    <td colspan="2">Total do Dia</td>
                                                    <td class="text-right">@day.TotalHoras.ToString("F2")h</td>
                                                    <td class="text-right">€@day.TotalPreco.ToString("F2")</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </article>
                            }
                        </div>

                        <div class="month-summary">
                            <span>Total do Mês</span>
                            <div class="month-summary-values">
                                <strong>@UserReport.TotalHoras.ToString("F2")h</strong>
                                <strong>€@UserReport.TotalPreco.ToString("F2")</strong>
                            </div>
                        </div>
                    }
                </section>
            </div>
        }
        else
        {
            <div class="reports-section">
                <section class="reports-card">
                    <div class="section-heading">
                        <h2>Selecione um Paciente</h2>
                    </div>

                    <div class="field">
                        <label>Paciente</label>
                        <select @bind="SelectedPatientId" @bind:after="LoadPatientReport">
                            <option value="">Escolha um paciente</option>
                            @foreach (var patient in AvailablePatients)
                            {
                                <option value="@patient.Id">@patient.Name</option>
                            }
                        </select>
                    </div>
                </section>

                @if (string.IsNullOrWhiteSpace(SelectedPatientId))
                {
                    <section class="reports-card reports-empty">
                        Selecione um paciente para consultar o relatório mensal.
                    </section>
                }
                else
                {
                    <div class="stats-grid">
                        <article class="stats-card stats-blue">
                            <div class="stats-label">Total de Horas</div>
                            <div class="stats-value">@PatientReport.TotalHoras.ToString("F2")h</div>
                        </article>
                        <article class="stats-card stats-green">
                            <div class="stats-label">Preço Total</div>
                            <div class="stats-value">€@PatientReport.TotalPreco.ToString("F2")</div>
                        </article>
                        <article class="stats-card stats-purple">
                            <div class="stats-label">Consultas</div>
                            <div class="stats-value">@PatientReport.TotalConsultas</div>
                        </article>
                    </div>

                    <section class="reports-card">
                        <div class="section-heading">
                            <h2>Detalhes por Dia</h2>
                        </div>

                        @if (PatientReport.Dias.Count == 0)
                        {
                            <div class="reports-empty">Nenhuma consulta encerrada neste período para este paciente.</div>
                        }
                        else
                        {
                            <div class="days-list">
                                @foreach (var day in PatientReport.Dias)
                                {
                                    <article class="day-card">
                                        <div class="day-header">
                                            <h3>Dia @day.Dia - @SelectedMonthLabel</h3>
                                            @if (day.Overtime)
                                            {
                                                <span class="status-pill status-danger">Overtime</span>
                                            }
                                        </div>

                                        <div class="table-wrap">
                                            <table class="reports-table">
                                                <thead>
                                                    <tr>
                                                        <th>Descrição</th>
                                                        <th class="text-right">Horas</th>
                                                        <th class="text-right">Preço</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var consultation in day.Consultas)
                                                    {
                                                        <tr>
                                                            <td class="truncate-cell">@consultation.Descricao</td>
                                                            <td class="text-right">@consultation.Horas.ToString("F2")h</td>
                                                            <td class="text-right">€@consultation.Preco.ToString("F2")</td>
                                                        </tr>
                                                    }
                                                    <tr class="summary-row">
                                                        <td>Total do Dia</td>
                                                        <td class="text-right">@day.TotalHoras.ToString("F2")h</td>
                                                        <td class="text-right">€@day.TotalPreco.ToString("F2")</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </article>
                                }
                            </div>

                            <div class="month-summary">
                                <span>Total do Mês</span>
                                <div class="month-summary-values">
                                    <strong>@PatientReport.TotalHoras.ToString("F2")h</strong>
                                    <strong>€@PatientReport.TotalPreco.ToString("F2")</strong>
                                </div>
                            </div>
                        }
                    </section>
                }
            </div>
        }
    </div>
}

@code {
    private readonly int[] Years = [2024, 2025, 2026];
    private readonly MonthOption[] Months =
    [
        new(0, "Janeiro"),
        new(1, "Fevereiro"),
        new(2, "Março"),
        new(3, "Abril"),
        new(4, "Maio"),
        new(5, "Junho"),
        new(6, "Julho"),
        new(7, "Agosto"),
        new(8, "Setembro"),
        new(9, "Outubro"),
        new(10, "Novembro"),
        new(11, "Dezembro")
    ];

    private bool IsLoading = true;
    private ReportsTab ActiveTab = ReportsTab.User;
    private int SelectedMonth = DateTime.Now.Month - 1;
    private int SelectedYear = DateTime.Now.Year;
    private string SelectedPatientId = string.Empty;
    private ConsultationData.UserItem? CurrentUser;
    private List<ConsultationData.PatientItem> AvailablePatients = [];
    private MonthlyReport UserReport { get; set; } = MonthlyReport.Empty();
    private MonthlyReport PatientReport { get; set; } = MonthlyReport.Empty();

    private string SelectedMonthLabel => Months.First(month => month.Value == SelectedMonth).Label;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var storedUser = await JSRuntime.InvokeAsync<StoredUser?>("profileStorage.getCurrentUser");
        CurrentUser = Store.FindUser(storedUser?.Email, storedUser?.Nome)
                      ?? Store.Users.FirstOrDefault(user => user.Id == "u1");

        LoadReportsPage();
        IsLoading = false;
        StateHasChanged();
    }

    private void LoadReportsPage()
    {
        if (CurrentUser is null)
        {
            AvailablePatients = [];
            UserReport = MonthlyReport.Empty();
            PatientReport = MonthlyReport.Empty();
            return;
        }

        AvailablePatients = Store.Consultations
            .Where(consultation => consultation.OwnerUserId == CurrentUser.Id)
            .Select(consultation => consultation.PatientId)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Join(Store.Patients, patientId => patientId, patient => patient.Id, (_, patient) => patient)
            .OrderBy(patient => patient.Name)
            .ToList();

        LoadUserReport();
        LoadPatientReport();
    }

    private void OnPeriodChanged()
    {
        LoadUserReport();
        LoadPatientReport();
    }

    private void LoadUserReport()
    {
        if (CurrentUser is null)
        {
            UserReport = MonthlyReport.Empty();
            return;
        }

        UserReport = BuildMonthlyReport(Store.Consultations.Where(consultation => consultation.OwnerUserId == CurrentUser.Id));
    }

    private void LoadPatientReport()
    {
        if (string.IsNullOrWhiteSpace(SelectedPatientId))
        {
            PatientReport = MonthlyReport.Empty();
            return;
        }

        PatientReport = BuildMonthlyReport(Store.Consultations.Where(consultation => consultation.PatientId == SelectedPatientId));
    }

    private MonthlyReport BuildMonthlyReport(IEnumerable<ConsultationData.ConsultationItem> consultations)
    {
        var filtered = consultations
            .Where(consultation => consultation.Status == ConsultationData.ConsultationStatus.Encerrada)
            .Where(consultation => consultation.EndAt.HasValue)
            .Where(consultation => consultation.EndAt!.Value.Month - 1 == SelectedMonth && consultation.EndAt.Value.Year == SelectedYear)
            .Select(consultation => new ConsultationSummary(
                consultation.Id,
                consultation.PatientName,
                consultation.Description,
                CalculateHours(consultation),
                CalculatePrice(consultation)))
            .OrderBy(summary => summary.Id)
            .ToList();

        var sourceConsultations = consultations
            .Where(consultation => consultation.Status == ConsultationData.ConsultationStatus.Encerrada)
            .Where(consultation => consultation.EndAt.HasValue)
            .Where(consultation => consultation.EndAt!.Value.Month - 1 == SelectedMonth && consultation.EndAt.Value.Year == SelectedYear)
            .OrderBy(consultation => consultation.EndAt)
            .ToList();

        var days = sourceConsultations
            .GroupBy(consultation => consultation.EndAt!.Value.Day)
            .OrderBy(group => group.Key)
            .Select(group =>
            {
                var dayConsultations = group.Select(consultation => new ConsultationSummary(
                    consultation.Id,
                    consultation.PatientName,
                    consultation.Description,
                    CalculateHours(consultation),
                    CalculatePrice(consultation)))
                    .ToList();

                var totalHours = dayConsultations.Sum(consultation => consultation.Horas);
                var totalPrice = dayConsultations.Sum(consultation => consultation.Preco);

                return new DailyReport(group.Key, totalHours, totalPrice, totalHours > 8d, dayConsultations);
            })
            .ToList();

        return new MonthlyReport(days.Sum(day => day.TotalHoras), days.Sum(day => day.TotalPreco), days.Sum(day => day.Consultas.Count), days);
    }

    private static double CalculateHours(ConsultationData.ConsultationItem consultation)
    {
        if (consultation.StartAt is null || consultation.EndAt is null)
        {
            return 0d;
        }

        var totalHours = (consultation.EndAt.Value - consultation.StartAt.Value).TotalHours;
        return totalHours > 0 ? totalHours : 0d;
    }

    private static decimal CalculatePrice(ConsultationData.ConsultationItem consultation)
    {
        if (consultation.ChargingType == ConsultationData.ChargingType.Fixo)
        {
            return consultation.FixedPrice ?? 0m;
        }

        var hours = CalculateHours(consultation);
        return Math.Round((decimal)hours * (consultation.HourlyPrice ?? 0m), 2);
    }

    private enum ReportsTab
    {
        User,
        Patient
    }

    private sealed record MonthOption(int Value, string Label);
    private sealed record ConsultationSummary(string Id, string PacienteNome, string Descricao, double Horas, decimal Preco);
    private sealed record DailyReport(int Dia, double TotalHoras, decimal TotalPreco, bool Overtime, List<ConsultationSummary> Consultas);
    private sealed record MonthlyReport(double TotalHoras, decimal TotalPreco, int TotalConsultas, List<DailyReport> Dias)
    {
        public static MonthlyReport Empty() => new(0d, 0m, 0, []);
    }

    private sealed class StoredUser
    {
        [JsonPropertyName("nome")]
        public string? Nome { get; set; }

        [JsonPropertyName("email")]
        public string? Email { get; set; }
    }
}
