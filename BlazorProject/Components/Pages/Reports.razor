@page "/relatorios"
@* Removemos os @inject por agora para não dar erro de compilação. Depois podes injetar os teus serviços reais! *@

<PageTitle>Relatórios</PageTitle>

<div class="container-fluid py-4">
    <div class="mb-4">
        <h1 class="h2 mb-1">Relatórios</h1>
        <p class="text-muted">Consulte relatórios mensais detalhados</p>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white fw-bold py-3">
            Período do Relatório
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label fw-semibold">Mês</label>
                    <select class="form-select" @bind="SelectedMonth" @bind:after="LoadAllReports">
                        @foreach (var month in Months)
                        {
                            <option value="@month.Key">@month.Value</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label fw-semibold">Ano</label>
                    <select class="form-select" @bind="SelectedYear" @bind:after="LoadAllReports">
                        @foreach (var year in Years)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "user" ? "active fw-bold" : "text-secondary")" 
                    @onclick="@(() => SetActiveTab("user"))">
                Meu Relatório
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "patient" ? "active fw-bold" : "text-secondary")" 
                    @onclick="@(() => SetActiveTab("patient"))">
                Relatório por Paciente
            </button>
        </li>
    </ul>

    @if (ActiveTab == "user" && UserReport != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-4">
                <div class="card shadow-sm h-100 border-start border-primary border-4">
                    <div class="card-body">
                        <h6 class="text-muted mb-2"><span class="text-primary me-2">⏱</span>Total de Horas</h6>
                        <h3 class="mb-0">@UserReport.TotalHoras.ToString("F2")h</h3>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="card shadow-sm h-100 border-start border-success border-4">
                    <div class="card-body">
                        <h6 class="text-muted mb-2"><span class="text-success me-2">📈</span>Receita Total</h6>
                        <h3 class="mb-0">€@UserReport.TotalPreco.ToString("F2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="card shadow-sm h-100 border-start border-info border-4">
                    <div class="card-body">
                        <h6 class="text-muted mb-2"><span class="text-info me-2">📄</span>Consultas Encerradas</h6>
                        <h3 class="mb-0">@UserReport.Dias.Sum(d => d.Consultas.Count)</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white fw-bold py-3">Detalhes por Dia</div>
            <div class="card-body">
                @if (!UserReport.Dias.Any())
                {
                    <div class="text-center text-muted py-5">
                        <p>Nenhuma consulta encerrada neste período.</p>
                    </div>
                }
                else
                {
                    @foreach (var day in UserReport.Dias)
                    {
                        <div class="border rounded p-3 mb-4 bg-light">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="mb-0 text-dark">Dia @day.Dia - @Months[SelectedMonth]</h5>
                                @if (day.Overtime)
                                {
                                    <span class="badge bg-danger">⚠️ Overtime</span>
                                }
                            </div>

                            <div class="table-responsive">
                                <table class="table table-hover table-bordered mb-0 bg-white">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Paciente</th>
                                            <th>Descrição</th>
                                            <th class="text-end">Horas</th>
                                            <th class="text-end">Preço</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var consulta in day.Consultas)
                                        {
                                            <tr>
                                                <td class="align-middle">@consulta.PacienteNome</td>
                                                <td class="align-middle text-truncate" style="max-width: 200px;">@consulta.Descricao</td>
                                                <td class="align-middle text-end">@consulta.Horas.ToString("F2")h</td>
                                                <td class="align-middle text-end">€@consulta.Preco.ToString("F2")</td>
                                            </tr>
                                        }
                                        <tr class="table-secondary fw-bold">
                                            <td colspan="2" class="align-middle">Total do Dia</td>
                                            <td class="align-middle text-end">@day.TotalHoras.ToString("F2")h</td>
                                            <td class="align-middle text-end">€@day.TotalPreco.ToString("F2")</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-4">
                        <h4 class="mb-0">Total do Mês</h4>
                        <div class="d-flex gap-4">
                            <h4 class="mb-0 text-primary">@UserReport.TotalHoras.ToString("F2")h</h4>
                            <h4 class="mb-0 text-success">€@UserReport.TotalPreco.ToString("F2")</h4>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (ActiveTab == "patient")
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white fw-bold py-3">Selecione um Paciente</div>
            <div class="card-body">
                <select class="form-select" @bind="SelectedPatientId" @bind:after="LoadPatientReport">
                    <option value="" disabled selected>Escolha um paciente...</option>
                    @foreach (var patient in Patients)
                    {
                        <option value="@patient.Id">@patient.Nome</option>
                    }
                </select>
            </div>
        </div>

        @if (PatientReport != null && !string.IsNullOrEmpty(SelectedPatientId))
        {
            <div class="alert alert-info">
                Dados carregados para o paciente selecionado (a estrutura visual seria igual à de cima).
            </div>
        }
    }
</div>

@code {
    // -------------------------------------------------------------
    // ESTADO DA PÁGINA
    // -------------------------------------------------------------
    private int SelectedMonth = DateTime.Now.Month - 1;
    private int SelectedYear = DateTime.Now.Year;
    private string SelectedPatientId = string.Empty;
    private string ActiveTab = "user";

    private MonthlyReport? UserReport;
    private MonthlyReport? PatientReport;
    private List<Patient> Patients = new();

    private readonly int[] Years = { 2024, 2025, 2026 };
    private readonly Dictionary<int, string> Months = new()
    {
        { 0, "Janeiro" }, { 1, "Fevereiro" }, { 2, "Março" }, { 3, "Abril" },
        { 4, "Maio" }, { 5, "Junho" }, { 6, "Julho" }, { 7, "Agosto" },
        { 8, "Setembro" }, { 9, "Outubro" }, { 10, "Novembro" }, { 11, "Dezembro" }
    };

    // -------------------------------------------------------------
    // CICLO DE VIDA (Substitui o useEffect)
    // -------------------------------------------------------------
    protected override void OnInitialized()
    {
        // Aqui irias carregar os pacientes da BD. Estamos a usar Mock Data.
        Patients = new List<Patient>
        {
            new Patient { Id = "1", Nome = "João Silva" },
            new Patient { Id = "2", Nome = "Maria Santos" }
        };

        LoadAllReports();
    }

    private void SetActiveTab(string tab)
    {
        ActiveTab = tab;
    }

    private void LoadAllReports()
    {
        LoadUserReport();
        if (!string.IsNullOrEmpty(SelectedPatientId))
        {
            LoadPatientReport();
        }
    }

    private void LoadUserReport()
    {
        // Mock Data: A simular uma resposta da Base de Dados
        UserReport = new MonthlyReport
        {
            TotalHoras = 12.5,
            TotalPreco = 450.00,
            Dias = new List<DailyReport>
            {
                new DailyReport 
                { 
                    Dia = 15, 
                    TotalHoras = 4.5, 
                    TotalPreco = 150.00, 
                    Overtime = false,
                    Consultas = new List<Consulta>
                    {
                        new Consulta { PacienteNome = "João Silva", Descricao = "Consulta de Rotina", Horas = 2.0, Preco = 80.00 },
                        new Consulta { PacienteNome = "Maria Santos", Descricao = "Avaliação", Horas = 2.5, Preco = 70.00 }
                    }
                },
                new DailyReport 
                { 
                    Dia = 18, 
                    TotalHoras = 8.0, 
                    TotalPreco = 300.00, 
                    Overtime = true, // Exemplo de overtime a ligar o badge
                    Consultas = new List<Consulta>
                    {
                        new Consulta { PacienteNome = "João Silva", Descricao = "Tratamento Intensivo", Horas = 8.0, Preco = 300.00 }
                    }
                }
            }
        };
    }

    private void LoadPatientReport()
    {
        // Simular carregamento por paciente
        PatientReport = new MonthlyReport { TotalHoras = 5, TotalPreco = 150, Dias = new() };
    }

    // -------------------------------------------------------------
    // CLASSES DE MODELO (Temporárias para não dar erro)
    // -------------------------------------------------------------
    public class Patient { public string Id { get; set; } = ""; public string Nome { get; set; } = ""; }
    public class MonthlyReport { public double TotalHoras { get; set; } public double TotalPreco { get; set; } public List<DailyReport> Dias { get; set; } = new(); }
    public class DailyReport { public int Dia { get; set; } public double TotalHoras { get; set; } public double TotalPreco { get; set; } public bool Overtime { get; set; } public List<Consulta> Consultas { get; set; } = new(); }
    public class Consulta { public string PacienteNome { get; set; } = ""; public string Descricao { get; set; } = ""; public double Horas { get; set; } public double Preco { get; set; } }
}