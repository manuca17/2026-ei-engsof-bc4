@rendermode InteractiveServer
@using BlazorProject.Data.Models
@using BlazorProject.Services
@inject NavigationManager NavigationManager

<div class="sb-wrapper">

    <!-- Header com user info -->
    <div class="sb-header">
        <h2 class="sb-name">@GetDisplayName()</h2>
        <p class="sb-role">@GetSpecialty()</p>
    </div>

    
    <!-- Navegação principal -->
    <nav class="sb-nav">
        @if (CurrentUser?.IsAdmin == false) {
        <NavLink class="sb-link" href="dashboard" Match="NavLinkMatch.All">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/>
                <rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>
            </svg>
            Dashboard
        </NavLink>

        <NavLink class="sb-link" href="patients">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            Pacientes
        </NavLink>

        <NavLink class="sb-link" href="consultations">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
                <line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/>
                <line x1="3" x2="21" y1="10" y2="10"/>
            </svg>
            Consultas
        </NavLink>

        <NavLink class="sb-link" href="reports">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/>
                <line x1="6" x2="6" y1="20" y2="14"/>
            </svg>
            Relatórios
        </NavLink>

        <NavLink class="sb-link" href="profile">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="7" r="4"/>
                <path d="M5.5 21a6.5 6.5 0 0 1 13 0"/>
            </svg>
            Perfil
        </NavLink>
        }

        
            <!-- Separador + secção Admin -->
        
        @if (CurrentUser?.IsAdmin == true) {
        <NavLink class="sb-link" href="user-management">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M19 8v6"/><path d="M22 11h-6"/>
                </svg>
                Gestão de Utilizadores
            </NavLink>

            <NavLink class="sb-link" href="global-records">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <ellipse cx="12" cy="5" rx="9" ry="3"/>
                    <path d="M3 5V19A9 3 0 0 0 21 19V5"/>
                    <path d="M3 12A9 3 0 0 0 21 12"/>
                </svg>
                Registos Globais
            </NavLink>
        }
    </nav>

    <!-- Footer com botão Sair -->
    <div class="sb-footer">
        <button class="sb-logout" @onclick="HandleLogout">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" x2="9" y1="12" y2="12"/>
            </svg>
            Sair
        </button>
    </div>

</div>

@code {
    private Utilizador? CurrentUser => LoggedInUserContext.CurrentUser;

    private void HandleLogout()
    {
        LoggedInUserContext.Clear();
        NavigationManager.NavigateTo("/");
    }

    private string GetDisplayName() =>
        string.IsNullOrWhiteSpace(CurrentUser?.Nome) ? "Utilizador" : CurrentUser.Nome;

    private string GetSpecialty() =>
        string.IsNullOrWhiteSpace(CurrentUser?.Especialidade) ? "Sem especialidade" : CurrentUser.Especialidade!;
}
